# Never commit the real key.
GROQ_API_KEY=

# Model routing. All values can be changed without touching the architecture.
NANOLGA_CORE_MODEL=openai/gpt-oss-20b
NANOLGA_WORKER_MODEL=llama-3.1-8b-instant
NANOLGA_CCA_MODEL=openai/gpt-oss-20b

# Optional local state path.
NANOLGA_DB=.nanolga/nanolga.db
